# Copy to .env and fill in real values. NEVER commit the real .env.

# --- Slack (from api.slack.com/apps) ---
SLACK_BOT_TOKEN=xoxb-your-bot-token            # Bot User OAuth Token
SLACK_APP_TOKEN=xapp-your-app-level-token      # Socket Mode, scope connections:write

# --- LM Studio (open-source local stack — two ports, both agents at once) ---
# Download from HuggingFace (Q4_K_M quantization only):
#   Hermes (brain):   unsloth/Phi-4-mini-reasoning-GGUF      → port 1234
#   OpenClaw (hands): LiquidAI/LFM2.5-1.2B-Instruct-GGUF     → port 1235
# See MODEL_STACK.md for model selection rationale (Fugu rejected — closed source).
HERMES_BASE_URL=http://localhost:1234/v1
HERMES_MODEL=phi-4-mini-reasoning
OPENCLAW_BASE_URL=http://localhost:1235/v1
OPENCLAW_MODEL=liquid/lfm2.5-1.2b-instruct

# --- Optional cloud fallback (not part of open-source stack) ---
# GROQ_API_KEY=gsk_your-groq-key
# GROQ_MODEL=openai/gpt-oss-120b

# --- ngrok (live demo: Vercel frontend → ngrok → local Laravel) ---
# NGROK_URL=https://your-subdomain.ngrok-free.app

# --- Slack channel IDs (channel → View details → bottom) ---
CH_SPRINT_MAIN=C0XXXXXXX
CH_AGENT_CODER=C0XXXXXXX
CH_AGENT_LOG=C0XXXXXXX
