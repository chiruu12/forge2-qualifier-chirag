# Copy to .env and fill in real values. NEVER commit the real .env.

# --- Slack (from api.slack.com/apps) ---
SLACK_BOT_TOKEN=xoxb-your-bot-token            # Bot User OAuth Token
SLACK_APP_TOKEN=xapp-your-app-level-token      # Socket Mode, scope connections:write

# --- OpenAI: hands / executor (OpenClaw) — gpt-5.4-nano ---
OPENAI_API_KEY=sk-your-openai-key

# --- Fireworks: brain / planner (Hermes) — Kimi 2.6 ---
FIREWORKS_API_KEY=fw_your-fireworks-key        # model: accounts/fireworks/models/kimi-k2p6

# --- Slack channel IDs (channel -> View details -> bottom) ---
CH_SPRINT_MAIN=C0XXXXXXX
CH_AGENT_CODER=C0XXXXXXX
CH_AGENT_LOG=C0XXXXXXX
