# Copy to .env and fill in real values. NEVER commit the real .env.

# --- Port map ---
#   1234 — LM Studio Local Server (agents) — http://127.0.0.1:1234
#   7900 — Laravel API (Kanban backend)
LMSTUDIO_PORT=1234
LARAVEL_PORT=7900

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# --- LM Studio (MLX models @ 127.0.0.1:1234) ---
#   Hermes (brain):   lfm2.5-1.2b-thinking-mlx  (4-bit MLX)
#   OpenClaw (hands): liquid/lfm2.5-1.2b         (8-bit MLX)
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
HERMES_BASE_URL=http://127.0.0.1:1234/v1
HERMES_MODEL=lfm2.5-1.2b-thinking-mlx
OPENCLAW_BASE_URL=http://127.0.0.1:1234/v1
OPENCLAW_MODEL=liquid/lfm2.5-1.2b

# --- Laravel API ---
LARAVEL_API_URL=http://localhost:7900/api

# --- Optional cloud fallback ---
# GROQ_API_KEY=gsk_your-groq-key

# --- ngrok → Laravel :7900 ---
# NGROK_URL=https://your-subdomain.ngrok-free.app

# --- Slack channel IDs ---
CH_SPRINT_MAIN=C0XXXXXXX
CH_AGENT_CODER=C0XXXXXXX
CH_AGENT_LOG=C0XXXXXXX
