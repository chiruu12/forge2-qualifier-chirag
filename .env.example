# Copy to .env and fill in real values. NEVER commit the real .env.

# --- Slack (from api.slack.com/apps) ---
SLACK_BOT_TOKEN=xoxb-your-bot-token            # Bot User OAuth Token
SLACK_APP_TOKEN=xapp-your-app-level-token      # Socket Mode, scope connections:write

# --- LM Studio (free local stack — both agents) ---
# Download from HuggingFace (Q4_K_M quantization only):
#   Hermes (brain):  LiquidAI/LFM2.5-1.2B-Thinking-GGUF
#   OpenClaw (hands): LiquidAI/LFM2.5-1.2B-Instruct-GGUF
LMSTUDIO_BASE_URL=http://localhost:1234/v1
HERMES_MODEL=liquid/lfm2.5-1.2b-thinking
OPENCLAW_MODEL=liquid/lfm2.5-1.2b-instruct

# --- Optional free fallback (Groq — stronger brain if local VRAM is tight) ---
# GROQ_API_KEY=gsk_your-groq-key
# GROQ_MODEL=openai/gpt-oss-120b

# --- ngrok (live demo: Vercel frontend → ngrok → local Laravel) ---
# NGROK_URL=https://your-subdomain.ngrok-free.app

# --- Slack channel IDs (channel → View details → bottom) ---
CH_SPRINT_MAIN=C0XXXXXXX
CH_AGENT_CODER=C0XXXXXXX
CH_AGENT_LOG=C0XXXXXXX
