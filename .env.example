# Copy to .env and fill in real values. NEVER commit the real .env.

# --- Port map (defaults — override if needed) ---
#   7900 — LM Studio Local Server (agents)
#   7901 — Laravel API (Kanban backend)
LMSTUDIO_PORT=7900
LARAVEL_PORT=7901

# --- Slack (from api.slack.com/apps) ---
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# --- LM Studio (MLX models — single Local Server on port 7900) ---
#   Hermes (brain):   lfm2.5-1.2b-thinking-mlx  (4-bit MLX)
#   OpenClaw (hands): liquid/lfm2.5-1.2b         (8-bit MLX)
LMSTUDIO_BASE_URL=http://localhost:7900/v1
HERMES_BASE_URL=http://localhost:7900/v1
HERMES_MODEL=lfm2.5-1.2b-thinking-mlx
OPENCLAW_BASE_URL=http://localhost:7900/v1
OPENCLAW_MODEL=liquid/lfm2.5-1.2b

# --- Laravel API ---
LARAVEL_API_URL=http://localhost:7901/api

# --- Optional cloud fallback (not part of open-source stack) ---
# GROQ_API_KEY=gsk_your-groq-key
# GROQ_MODEL=openai/gpt-oss-120b

# --- ngrok (live demo: Vercel frontend → ngrok → local Laravel :7901) ---
# NGROK_URL=https://your-subdomain.ngrok-free.app

# --- Slack channel IDs ---
CH_SPRINT_MAIN=C0XXXXXXX
CH_AGENT_CODER=C0XXXXXXX
CH_AGENT_LOG=C0XXXXXXX
