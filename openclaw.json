{
  "_comment": "OpenClaw (hands/coder) config. Free stack: LFM2.5-Instruct Q4 via LM Studio. Secrets removed; tokens are env references.",
  "agents": {
    "defaults": {
      "workspace": "<repo-root>",
      "model": { "primary": "lmstudio/liquid/lfm2.5-1.2b-instruct" },
      "models": {
        "lmstudio/liquid/lfm2.5-1.2b-instruct": {},
        "lmstudio/liquid/lfm2.5-1.2b-thinking": {}
      }
    }
  },
  "gateway": {
    "mode": "local",
    "auth": { "mode": "token", "token": "REDACTED" },
    "port": 18789,
    "bind": "loopback",
    "tailscale": { "mode": "off", "resetOnExit": false }
  },
  "session": { "dmScope": "per-channel-peer" },
  "tools": { "profile": "coding" },
  "skills": { "install": { "nodeManager": "npm" } },
  "channels": {
    "slack": {
      "enabled": true,
      "mode": "socket",
      "appToken": { "source": "env", "provider": "default", "id": "SLACK_APP_TOKEN" },
      "botToken": { "source": "env", "provider": "default", "id": "SLACK_BOT_TOKEN" }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "lmstudio": {
        "baseUrl": "http://localhost:1234/v1",
        "apiKey": "lm-studio",
        "api": "openai-completions",
        "contextWindow": 32768,
        "models": [
          {
            "id": "liquid/lfm2.5-1.2b-instruct",
            "name": "LFM2.5 1.2B Instruct (Q4)",
            "api": "openai-completions",
            "input": ["text"]
          },
          {
            "id": "liquid/lfm2.5-1.2b-thinking",
            "name": "LFM2.5 1.2B Thinking (Q4)",
            "api": "openai-completions",
            "input": ["text"]
          }
        ]
      }
    }
  },
  "plugins": {
    "entries": {
      "slack": { "enabled": true },
      "codex": { "enabled": false }
    }
  }
}
